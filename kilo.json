{
  "$schema": "https://app.kilo.ai/config.json",
  "provider": {
    "anthropic": {
      "options": {
        "apiKey": "${KILO_API_KEY}"
      }
    }
  },
  "model": "anthropic/claude-sonnet-4-20250514",
  "mcp": {
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "Accept": "application/json",
        "X-Goog-Api-Key": "${GOOGLE_STITCH_API_KEY}"
      },
      "timeout": 300000
    }
  }
}
