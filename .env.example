# bl1nk-visual-mcp - Environment Variables

# Optional: MCP Server Configuration
# These are used if you want to run this as an MCP server
MCP_SERVER_PORT=3000
MCP_SERVER_HOST=localhost

# Optional: API Keys (if extending with external services)
# Leave empty if not using external services
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional: Feature Flags
ENABLE_TELEMETRY=false
DEBUG_MODE=false

# Optional: Project Settings
STORY_DEFAULT_ACT_COUNT=3
STORY_MIN_EVENTS=3
STORY_MAX_EVENTS=100
